{
  "schema": 1,
  "devLive": {
    "host": "127.0.0.1",
    "port": 4000,
    "protocol": "http",
    "proxy": "",
    "reload": "watch"
  },
  "distribution": {
    "webConfig": "versioned-path",
    "offlineConfig": "embed-required-only"
  },
  "lifecycle": {
    "developmentBranch": "dev",
    "productionBranches": ["main", "master"],
    "remote": "origin",
    "workflow": "release.yml",
    "hooksRoot": ".ia.rules/hooks"
  },
  "publicServices": {
    "githubApi": "https://api.github.com"
  },
  "publicClient": {
    "cacheTtlMs": 300000,
    "maxBytes": 262144,
    "retries": 2,
    "timeoutMs": 120000
  },
  "output": {
    "maxBytes": 8192,
    "maxLines": 50
  }
}
