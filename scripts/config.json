{
  "paths": {
    "source": "src",
    "distribution": "dist",
    "cache": ".cache/build",
    "catalog": "assets/config/apps.json",
    "sharedBrowserScript": "assets/js/documentos.js"
  },
  "site": {
    "publicBaseUrl": "https://tools.jcem.pro/"
  },
  "development": {
    "host": "127.0.0.1",
    "port": 4173,
    "rebuildDebounceMs": 180,
    "liveRoute": "/__live",
    "vendor": [
      {
        "url": "https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.8.0/html2pdf.bundle.min.js",
        "file": "node_modules/html2pdf.js/dist/html2pdf.bundle.min.js",
        "route": "/__vendor/html2pdf.bundle.min.js"
      },
      {
        "url": "https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.14.0/html2pdf.bundle.min.js",
        "file": "node_modules/html2pdf.js/dist/html2pdf.bundle.min.js",
        "route": "/__vendor/html2pdf.bundle.min.js"
      },
      {
        "url": "https://cdnjs.cloudflare.com/ajax/libs/zepto/1.2.0/zepto.min.js",
        "file": "node_modules/zepto/dist/zepto.min.js",
        "route": "/__vendor/zepto.min.js"
      }
    ]
  },
  "publication": {
    "primaryBranch": "master",
    "versionIndex": "version.json",
    "requiredFiles": ["CNAME", ".nojekyll"],
    "forbiddenRoots": ["src", "dist", "README.md"],
    "bundlePattern": ".bundle.zip",
    "legacyBundlePattern": ".bundle.html"
  },
  "build": {
    "browserScripts": [
      {
        "source": "src/assets/js/consent.ts",
        "output": "assets/js/consent.js"
      },
      {
        "source": "src/assets/js/dashboard.ts",
        "output": "assets/js/dashboard.js"
      },
      {
        "source": "src/assets/js/documentos.ts",
        "output": "assets/js/documentos.js"
      },
      {
        "source": "src/oficios/admissional/admissional.ts",
        "output": "oficios/admissional/admissional.js"
      },
      {
        "source": "src/faturamento/faturamento.ts",
        "output": "faturamento/faturamento.js"
      },
      {
        "source": "src/csv-bd/bd.ts",
        "output": "csv-bd/bd.js"
      }
    ],
    "bookmarklets": [
      {
        "source": "src/favoritos/remover.paywall.ts",
        "output": "favoritos/remover.paywall.js"
      },
      {
        "source": "src/favoritos/dark.discourse.ts",
        "output": "favoritos/dark.discourse.js"
      }
    ],
    "rootPassthroughFiles": [
      "CNAME"
    ],
    "generatedRootFiles": {
      ".nojekyll": ""
    }
  }
}
